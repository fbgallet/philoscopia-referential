{
  "name": "philoscopia-mcp",
  "version": "0.6.1",
  "description": "MCP server for the Philoscopia referential: explore 80 axes of philosophical positions, compare figures, and build your own philosophical profile in a local, private workspace.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "philoscopia-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "corpus"
  ],
  "scripts": {
    "build": "node scripts/bundle-skills.mjs && tsc -p tsconfig.json",
    "prepack": "npm run build && node scripts/bundle-corpus.mjs",
    "smoke": "npm run build && node scripts/smoke-test.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fbgallet/philoscopia-referential.git",
    "directory": "mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "ajv": "^8.17.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
