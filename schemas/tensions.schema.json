{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fbgallet/philoscopia-referential/blob/main/schemas/tensions.schema.json",
  "title": "tensions",
  "description": "A justified pair of positions in tension within one profile. Generated from the source Zod schemas. This captures structure only; cross-file and cross-field rules (reference resolution, graph acyclicity, pole-count-by-type, weights summing to 1, etc.) are enforced by the corpus validator, not expressible in JSON Schema.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "T_T",
        "T_V"
      ]
    },
    "a": {
      "type": "object",
      "properties": {
        "axisId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "predicate": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "scalarRange"
                },
                "min": {
                  "type": "number",
                  "minimum": -1,
                  "maximum": 1
                },
                "max": {
                  "type": "number",
                  "minimum": -1,
                  "maximum": 1
                }
              },
              "required": [
                "kind",
                "min",
                "max"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "minPoleWeight"
                },
                "poleId": {
                  "type": "string",
                  "pattern": "^[A-Z][A-Z0-9_]*$"
                },
                "min": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              },
              "required": [
                "kind",
                "poleId",
                "min"
              ],
              "additionalProperties": false
            }
          ]
        }
      },
      "required": [
        "axisId",
        "predicate"
      ],
      "additionalProperties": false
    },
    "b": {
      "type": "object",
      "properties": {
        "axisId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "predicate": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "scalarRange"
                },
                "min": {
                  "type": "number",
                  "minimum": -1,
                  "maximum": 1
                },
                "max": {
                  "type": "number",
                  "minimum": -1,
                  "maximum": 1
                }
              },
              "required": [
                "kind",
                "min",
                "max"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "minPoleWeight"
                },
                "poleId": {
                  "type": "string",
                  "pattern": "^[A-Z][A-Z0-9_]*$"
                },
                "min": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              },
              "required": [
                "kind",
                "poleId",
                "min"
              ],
              "additionalProperties": false
            }
          ]
        }
      },
      "required": [
        "axisId",
        "predicate"
      ],
      "additionalProperties": false
    },
    "explanation": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "updatedAt": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "a",
    "b",
    "explanation",
    "updatedAt"
  ],
  "additionalProperties": false
}
