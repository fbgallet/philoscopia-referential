{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fbgallet/philoscopia-referential/blob/main/schemas/glossary.schema.json",
  "title": "glossary",
  "description": "A glossary entry, the target of a <c id='…'> tag. Generated from the source Zod schemas. This captures structure only; cross-file and cross-field rules (reference resolution, graph acyclicity, pole-count-by-type, weights summing to 1, etc.) are enforced by the corpus validator, not expressible in JSON Schema.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "term": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "definition": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "relatedAxes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      }
    },
    "relatedTerms": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "figure": {
      "type": "object",
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "object",
          "properties": {
            "fr": {
              "type": "string",
              "minLength": 1
            },
            "en": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "fr",
            "en"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "slug",
        "name"
      ],
      "additionalProperties": false
    },
    "positions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "axisId": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "poleId": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        },
        "required": [
          "axisId",
          "poleId"
        ],
        "additionalProperties": false
      }
    },
    "updatedAt": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "term",
    "definition",
    "relatedAxes",
    "relatedTerms",
    "updatedAt"
  ],
  "additionalProperties": false
}
