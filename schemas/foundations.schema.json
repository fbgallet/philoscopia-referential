{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fbgallet/philoscopia-referential/blob/main/schemas/foundations.schema.json",
  "title": "foundations",
  "description": "A grounding edge: a descriptive belief that grounds another belief. Generated from the source Zod schemas. This captures structure only; cross-file and cross-field rules (reference resolution, graph acyclicity, pole-count-by-type, weights summing to 1, etc.) are enforced by the corpus validator, not expressible in JSON Schema.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "ground": {
      "type": "object",
      "properties": {
        "axisId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "poleId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "median": {
          "type": "boolean",
          "const": true
        }
      },
      "required": [
        "axisId"
      ],
      "additionalProperties": false
    },
    "grounded": {
      "type": "object",
      "properties": {
        "axisId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "poleId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "median": {
          "type": "boolean",
          "const": true
        }
      },
      "required": [
        "axisId"
      ],
      "additionalProperties": false
    },
    "kind": {
      "type": "string",
      "enum": [
        "T_T",
        "T_V"
      ]
    },
    "strength": {
      "type": "string",
      "enum": [
        "STRONG",
        "MEDIUM",
        "WEAK"
      ]
    },
    "explanation": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "updatedAt": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "ground",
    "grounded",
    "kind",
    "strength",
    "explanation",
    "updatedAt"
  ],
  "additionalProperties": false
}
