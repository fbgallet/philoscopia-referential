{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fbgallet/philoscopia-referential/blob/main/schemas/axes.schema.json",
  "title": "axes",
  "description": "One axis of the referential: a live philosophical question with its poles. Generated from the source Zod schemas. This captures structure only; cross-file and cross-field rules (reference resolution, graph acyclicity, pole-count-by-type, weights summing to 1, etc.) are enforced by the corpus validator, not expressible in JSON Schema.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "relation": {
      "type": "string",
      "enum": [
        "TRUTH",
        "SELF",
        "OTHERS",
        "WORLD"
      ]
    },
    "territory": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "label": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "question": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "stakes": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "layer": {
      "type": "string",
      "enum": [
        "THEORY",
        "VALUE"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "BIPOLAR",
        "BIPOLAR_MEDIAN",
        "TRIANGULAR",
        "CATEGORICAL",
        "CATEGORICAL_ORDERED"
      ]
    },
    "poles": {
      "minItems": 2,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "label": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          },
          "description": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          },
          "concept": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "figures": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "slug": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$"
                },
                "name": {
                  "type": "object",
                  "properties": {
                    "fr": {
                      "type": "string",
                      "minLength": 1
                    },
                    "en": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "fr",
                    "en"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "slug",
                "name"
              ],
              "additionalProperties": false
            }
          },
          "orphan": {
            "type": "boolean"
          },
          "nuances": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fr": {
                  "type": "string",
                  "minLength": 1
                },
                "en": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "fr",
                "en"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "id",
          "label",
          "description",
          "figures"
        ],
        "additionalProperties": false
      }
    },
    "commonOpinion": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "medianLabel": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "medianDescription": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "core": {
      "type": "boolean"
    },
    "difficulty": {
      "anyOf": [
        {
          "type": "number",
          "const": 1
        },
        {
          "type": "number",
          "const": 2
        },
        {
          "type": "number",
          "const": 3
        }
      ]
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      }
    },
    "relatedAxes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      }
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "resolution": {
            "type": "string",
            "enum": [
              "SURFACED",
              "LATENT"
            ]
          },
          "object": {
            "type": "string",
            "enum": [
              "INDIVIDUAL",
              "RELATION",
              "STRUCTURE"
            ]
          },
          "mode": {
            "type": "string",
            "enum": [
              "DESCRIPTIVE",
              "PRESCRIPTIVE",
              "PRACTICAL"
            ]
          },
          "relation": {
            "type": "string",
            "enum": [
              "SUBPROBLEM",
              "RELATED"
            ]
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fr": {
                  "type": "string",
                  "minLength": 1
                },
                "en": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "fr",
                "en"
              ],
              "additionalProperties": false
            }
          },
          "sphere": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "poles": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]*$"
            }
          },
          "objectLabel": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          },
          "anchors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "object",
                  "properties": {
                    "fr": {
                      "type": "string",
                      "minLength": 1
                    },
                    "en": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "fr",
                    "en"
                  ],
                  "additionalProperties": false
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "PHILOSOPHER",
                    "MOVEMENT",
                    "TRADITION"
                  ]
                },
                "slug": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$"
                }
              },
              "required": [
                "name",
                "kind"
              ],
              "additionalProperties": false
            }
          },
          "doorways": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "axis": {
                  "type": "string",
                  "pattern": "^[A-Z][A-Z0-9_]*$"
                },
                "problem": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$"
                }
              },
              "required": [
                "axis"
              ],
              "additionalProperties": false
            }
          },
          "title": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          },
          "explicitation": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          },
          "ref": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "QUESTION",
                  "THOUGHT_EXPERIMENT",
                  "SCENARIO"
                ]
              },
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              }
            },
            "required": [
              "kind",
              "id"
            ],
            "additionalProperties": false
          },
          "practices": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            }
          }
        },
        "required": [
          "id",
          "resolution",
          "object",
          "mode"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "id",
    "relation",
    "territory",
    "label",
    "question",
    "layer",
    "type",
    "poles",
    "core",
    "difficulty",
    "clusters",
    "relatedAxes"
  ],
  "additionalProperties": false
}
