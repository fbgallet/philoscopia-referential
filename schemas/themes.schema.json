{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fbgallet/philoscopia-referential/blob/main/schemas/themes.schema.json",
  "title": "themes",
  "description": "A discovery theme: a general-public entry word (a life theme, a school-programme notion) mapped to the axes that treat it. Generated from the source Zod schemas. This captures structure only; cross-file and cross-field rules (reference resolution, graph acyclicity, pole-count-by-type, weights summing to 1, etc.) are enforced by the corpus validator, not expressible in JSON Schema.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "label": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "aliases": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "en": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "featured": {
      "type": "boolean"
    },
    "axes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      }
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "axis": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "problem": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "required": [
          "axis",
          "problem"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "id",
    "label",
    "axes"
  ],
  "additionalProperties": false
}
