{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fbgallet/philoscopia-referential/blob/main/schemas/influences.schema.json",
  "title": "influences",
  "description": "A directed historical influence edge between two figures/movements. Generated from the source Zod schemas. This captures structure only; cross-file and cross-field rules (reference resolution, graph acyclicity, pole-count-by-type, weights summing to 1, etc.) are enforced by the corpus validator, not expressible in JSON Schema.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "from": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "PHILOSOPHER",
            "MOVEMENT"
          ]
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        }
      },
      "required": [
        "kind",
        "slug"
      ],
      "additionalProperties": false
    },
    "to": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "PHILOSOPHER",
            "MOVEMENT"
          ]
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        }
      },
      "required": [
        "kind",
        "slug"
      ],
      "additionalProperties": false
    },
    "directness": {
      "type": "string",
      "enum": [
        "ATTESTED",
        "INDIRECT"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "CONTINUES",
        "REACTS_AGAINST",
        "SYNTHESIZES",
        "TRANSMITS",
        "REINTERPRETS"
      ]
    },
    "strength": {
      "type": "string",
      "enum": [
        "STRONG",
        "MEDIUM",
        "WEAK"
      ]
    },
    "note": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "sources": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fr": {
            "type": "string",
            "minLength": 1
          },
          "en": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "fr",
          "en"
        ],
        "additionalProperties": false
      }
    },
    "updatedAt": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "from",
    "to",
    "directness",
    "mode",
    "strength",
    "note",
    "updatedAt"
  ],
  "additionalProperties": false
}
