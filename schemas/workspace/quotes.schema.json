{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fbgallet/philoscopia-referential/blob/main/schemas/workspace/quotes.schema.json",
  "title": "workspace/quotes",
  "description": "The florilège (commonplace book): quotations kept verbatim, with gloss and personal note. Part of the user workspace format (my-philosophy/): monolingual, personal, local-first files written by the Philoscopia MCP server and exploration skills. Structure only; write-time rules (e.g. POSITIONED requires a value, ref resolution against the pinned referential) are enforced by the tools.",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "text": {
        "type": "string",
        "minLength": 1
      },
      "source": {
        "type": "string"
      },
      "quoteRef": {
        "type": "string",
        "pattern": "^q:[a-z0-9][a-z0-9-]*$"
      },
      "explanation": {
        "type": "string"
      },
      "note": {
        "type": "string"
      },
      "anchors": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^(ax:[A-Z][A-Z0-9_]*|pole:[A-Z][A-Z0-9_]*\\/[A-Z][A-Z0-9_]*|(c|ph|mv|chr|te|w|problem|arg):[a-z0-9][a-z0-9-]*)$"
        }
      },
      "createdAt": {
        "type": "string"
      },
      "updatedAt": {
        "type": "string"
      }
    },
    "required": [
      "id",
      "text",
      "createdAt"
    ],
    "additionalProperties": false
  }
}
