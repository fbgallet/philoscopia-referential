{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fbgallet/philoscopia-referential/blob/main/schemas/movements.schema.json",
  "title": "movements",
  "description": "A movement/school profile: its definitory and typical positions. Generated from the source Zod schemas. This captures structure only; cross-file and cross-field rules (reference resolution, graph acyclicity, pole-count-by-type, weights summing to 1, etc.) are enforced by the corpus validator, not expressible in JSON Schema.",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "const": "MOVEMENT"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "tagline": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "entries": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "axisId": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "status": {
            "type": "string",
            "enum": [
              "POSITIONED",
              "NO_POSITION",
              "CONTEXTUALIST",
              "REJECTS_ALTERNATIVE",
              "NOT_APPLICABLE"
            ]
          },
          "declaredValue": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "scalar"
                  },
                  "value": {
                    "type": "number",
                    "minimum": -1,
                    "maximum": 1
                  }
                },
                "required": [
                  "kind",
                  "value"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "weights"
                  },
                  "weights": {
                    "minItems": 2,
                    "type": "array",
                    "items": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    }
                  }
                },
                "required": [
                  "kind",
                  "weights"
                ],
                "additionalProperties": false
              }
            ]
          },
          "practicedValue": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "scalar"
                  },
                  "value": {
                    "type": "number",
                    "minimum": -1,
                    "maximum": 1
                  }
                },
                "required": [
                  "kind",
                  "value"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "weights"
                  },
                  "weights": {
                    "minItems": 2,
                    "type": "array",
                    "items": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    }
                  }
                },
                "required": [
                  "kind",
                  "weights"
                ],
                "additionalProperties": false
              }
            ]
          },
          "epistemicStatus": {
            "type": "string",
            "enum": [
              "EXPLICIT",
              "INFERABLE",
              "EXTRAPOLATED",
              "UNDOCUMENTED"
            ]
          },
          "salience": {
            "type": "string",
            "enum": [
              "MAJOR",
              "MINOR",
              "NOT_RELEVANT"
            ]
          },
          "justification": {
            "type": "object",
            "properties": {
              "text": {
                "type": "object",
                "properties": {
                  "fr": {
                    "type": "string",
                    "minLength": 1
                  },
                  "en": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "fr",
                  "en"
                ],
                "additionalProperties": false
              },
              "references": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "fr": {
                      "type": "string",
                      "minLength": 1
                    },
                    "en": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "fr",
                    "en"
                  ],
                  "additionalProperties": false
                }
              },
              "quote": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "object",
                    "properties": {
                      "fr": {
                        "type": "string",
                        "minLength": 1
                      },
                      "en": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "fr",
                      "en"
                    ],
                    "additionalProperties": false
                  },
                  "source": {
                    "type": "object",
                    "properties": {
                      "fr": {
                        "type": "string",
                        "minLength": 1
                      },
                      "en": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "fr",
                      "en"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "text"
                ],
                "additionalProperties": false
              },
              "strength": {
                "type": "string",
                "enum": [
                  "STRONG",
                  "MEDIUM",
                  "WEAK"
                ]
              }
            },
            "required": [
              "text",
              "references",
              "strength"
            ],
            "additionalProperties": false
          },
          "note": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "axisId",
          "status"
        ],
        "additionalProperties": false
      }
    },
    "structuring": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "axisId": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "thesis": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "axisId"
        ],
        "additionalProperties": false
      }
    },
    "updatedAt": {
      "type": "string"
    },
    "validation": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "DOUBLE_LLM_PASS",
            "EXPERT_REVIEW",
            "NOT_VALIDATED"
          ]
        },
        "convergenceScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "method"
      ],
      "additionalProperties": false
    },
    "period": {
      "type": "object",
      "properties": {
        "from": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "to": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false
    },
    "keyFigures": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "slug",
          "name"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "kind",
    "id",
    "name",
    "summary",
    "entries",
    "updatedAt",
    "validation",
    "keyFigures"
  ],
  "additionalProperties": false
}
