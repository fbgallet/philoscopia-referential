{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fbgallet/philoscopia-referential/blob/main/schemas/thought-experiments.schema.json",
  "title": "thought-experiments",
  "description": "A thought experiment linked to the axes it puts under stress. Generated from the source Zod schemas. This captures structure only; cross-file and cross-field rules (reference resolution, graph acyclicity, pole-count-by-type, weights summing to 1, etc.) are enforced by the corpus validator, not expressible in JSON Schema.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "description": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "nature": {
      "type": "string",
      "enum": [
        "IMAGINED",
        "REAL"
      ]
    },
    "source": {
      "type": "object",
      "properties": {
        "author": {
          "type": "object",
          "properties": {
            "fr": {
              "type": "string",
              "minLength": 1
            },
            "en": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "fr",
            "en"
          ],
          "additionalProperties": false
        },
        "work": {
          "type": "object",
          "properties": {
            "fr": {
              "type": "string",
              "minLength": 1
            },
            "en": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "fr",
            "en"
          ],
          "additionalProperties": false
        },
        "year": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "author"
      ],
      "additionalProperties": false
    },
    "question": {
      "type": "object",
      "properties": {
        "fr": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "fr",
        "en"
      ],
      "additionalProperties": false
    },
    "axisIds": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      }
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "label": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          },
          "hints": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "axisId": {
                  "type": "string",
                  "pattern": "^[A-Z][A-Z0-9_]*$"
                },
                "value": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "scalar"
                        },
                        "value": {
                          "type": "number",
                          "minimum": -1,
                          "maximum": 1
                        }
                      },
                      "required": [
                        "kind",
                        "value"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "weights"
                        },
                        "weights": {
                          "minItems": 2,
                          "type": "array",
                          "items": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          }
                        }
                      },
                      "required": [
                        "kind",
                        "weights"
                      ],
                      "additionalProperties": false
                    }
                  ]
                },
                "weight": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 3
                }
              },
              "required": [
                "axisId",
                "value"
              ],
              "additionalProperties": false
            }
          },
          "discussion": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "label",
          "hints"
        ],
        "additionalProperties": false
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "OBJECTS",
              "SUPPORTS",
              "RAISES_PROBLEM",
              "TESTS_CONCEPT",
              "ILLUSTRATES"
            ]
          },
          "position": {
            "type": "object",
            "properties": {
              "axisId": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9_]*$"
              },
              "poleId": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9_]*$"
              },
              "median": {
                "type": "boolean",
                "const": true
              }
            },
            "required": [
              "axisId"
            ],
            "additionalProperties": false
          },
          "attacks": {
            "type": "string",
            "enum": [
              "POSITION",
              "REASONING"
            ]
          },
          "argumentId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "problems": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            }
          },
          "summary": {
            "type": "object",
            "properties": {
              "fr": {
                "type": "string",
                "minLength": 1
              },
              "en": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "fr",
              "en"
            ],
            "additionalProperties": false
          },
          "reconstruction": {
            "type": "object",
            "properties": {
              "development": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "fr": {
                      "type": "string",
                      "minLength": 1
                    },
                    "en": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "fr",
                    "en"
                  ],
                  "additionalProperties": false
                }
              },
              "conclusion": {
                "type": "object",
                "properties": {
                  "fr": {
                    "type": "string",
                    "minLength": 1
                  },
                  "en": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "fr",
                  "en"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "development"
            ],
            "additionalProperties": false
          },
          "responses": {
            "minItems": 2,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$"
                },
                "label": {
                  "type": "object",
                  "properties": {
                    "fr": {
                      "type": "string",
                      "minLength": 1
                    },
                    "en": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "fr",
                    "en"
                  ],
                  "additionalProperties": false
                },
                "hints": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "axisId": {
                        "type": "string",
                        "pattern": "^[A-Z][A-Z0-9_]*$"
                      },
                      "value": {
                        "oneOf": [
                          {
                            "type": "object",
                            "properties": {
                              "kind": {
                                "type": "string",
                                "const": "scalar"
                              },
                              "value": {
                                "type": "number",
                                "minimum": -1,
                                "maximum": 1
                              }
                            },
                            "required": [
                              "kind",
                              "value"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "properties": {
                              "kind": {
                                "type": "string",
                                "const": "weights"
                              },
                              "weights": {
                                "minItems": 2,
                                "type": "array",
                                "items": {
                                  "type": "number",
                                  "minimum": 0,
                                  "maximum": 1
                                }
                              }
                            },
                            "required": [
                              "kind",
                              "weights"
                            ],
                            "additionalProperties": false
                          }
                        ]
                      },
                      "weight": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 3
                      }
                    },
                    "required": [
                      "axisId",
                      "value"
                    ],
                    "additionalProperties": false
                  }
                },
                "discussion": {
                  "type": "object",
                  "properties": {
                    "fr": {
                      "type": "string",
                      "minLength": 1
                    },
                    "en": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "fr",
                    "en"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "id",
                "label",
                "hints"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "role",
          "position"
        ],
        "additionalProperties": false
      }
    },
    "updatedAt": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "description",
    "source",
    "question",
    "axisIds",
    "updatedAt"
  ],
  "additionalProperties": false
}
